# Solana RPC provider. Default uses Alchemy ; override SOLANA_RPC_URL for
# any other provider (Helius, QuickNode, public mainnet…).
ALCHEMY_API_KEY=your_alchemy_api_key_here
# Optional: full RPC URL. If set, this takes precedence over ALCHEMY_API_KEY.
# Example for Helius : https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# Example for QuickNode : https://your-endpoint.solana-mainnet.quiknode.pro/TOKEN/
# SOLANA_RPC_URL=

# Mainnet addresses
BURN_ADDRESS=4Upb3WBoMSAaMC3eytHvSnL4hYLvDEL8zpQr4Q9U6JsB
REFUND_ADDRESS=DWUFCjBxqDuXpUGF8KnVzhAuz2uhRyfrky4aFc2JvvgH

# XBT mint on Solana - the official $XBT (vanity suffix "27xbt", 6 decimals).
# Filtering on this prevents copycat tokens from polluting the burn count.
XBT_MINT=AdsLPtW1KvKAw3QQLDST3M9cm57TeXZpbAhiKS27xbt

# D17 supply / event allocation
# Confirmed by @xbt2027 - 1B total supply, 30M (3%) per event, 5 events for XBT burners.
D17_TOTAL_SUPPLY=1000000000
EVENT_ALLOCATION=30000000
TOTAL_EVENTS=5

# Polling interval in seconds. 300s keeps us under most free-tier ceilings.
POLL_INTERVAL=300
# Wait this many seconds before retrying after a startup failure.
INIT_RETRY_INTERVAL=300
